# Archon Trust Registry Configuration

# Registry Identity
REGISTRY_DID=did:cid:your-registry-did
REGISTRY_NAME=My Trust Registry

# Gatekeeper Connection
GATEKEEPER_URL=https://archon.technology

# Resource Format: "did" | "name" | "both"
RESOURCE_FORMAT=both

# Server
PORT=4260

# Group DIDs (from your archon.social or equivalent setup)
OWNER_GROUP=did:cid:your-owner-group
ADMIN_GROUP=did:cid:your-admin-group
MODERATOR_GROUP=did:cid:your-moderator-group
MEMBER_GROUP=did:cid:your-member-group
